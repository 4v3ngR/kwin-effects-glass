#: src/kcm/blur_config.cpp:34
msgid "Glass"
msgstr "Verre"

#: src/kcm/blur_config.cpp:67
#, kde-format
msgid ""
"<p>Specify one window class per line.</p><p>Use <code>$blank</code> to match "
"empty window classes.<br/>Use <code>$$</code> for literal dollar sign.</p>"
msgstr ""
"<p>Spécifiez une fenêtre par ligne.</p><p>Utilisez <code>$blank</code> pour "
"spécifier les fenêtres sans nom de classe.<br/>Utilisez <code>$$</code> pour "
"mettre un symbole dollar.</p>"

